SECRET_KEY=long-random-string-for-csrf-sessions

# Behind Traefik / nginx / Caddy TLS termination (recommended on HTTPS hosts)
# TRUST_PROXY=true

# If the form is embedded in an iframe on another site over HTTPS, use:
# SESSION_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true

# Set false to hide the form on https://form-send.example/ (top-level only). Iframe embeds keep working.
# ALLOW_HOST_LANDING_PAGE=true

MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=app-password
MAIL_SENDER=you@example.com
MAIL_USE_TLS=true

# Subject line for emails from the form (optional; default below)
# MAIL_SUBJECT=[Resonance] New message

# Optional: who receives submissions (defaults to MAIL_SENDER).
# Comma or semicolon separated for multiple addresses:
# MAIL_RECIPIENT=team@example.com,other@example.com

# Optional: lock embedding to specific sites (default in app is *)
# FRAME_ANCESTORS=https://mysite.com https://app.mysite.com
