SECRET_KEY=long-random-string-for-csrf-sessions

# If the form is embedded in an iframe on another site over HTTPS, use:
# SESSION_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true

MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=app-password
MAIL_SENDER=you@example.com
MAIL_USE_TLS=true

# Optional: inbox that receives submissions (defaults to MAIL_SENDER)
# MAIL_RECIPIENT=team@example.com

# Optional: lock embedding to specific sites (default in app is *)
# FRAME_ANCESTORS=https://mysite.com https://app.mysite.com
